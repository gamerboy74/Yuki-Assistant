# Copy this file to .env and fill in your values

OPENAI_API_KEY=your-openai-api-key-here

# --- AI Provider Settings ---
# Options: ollama | openai | auto
# auto = try Ollama first, fall back to OpenAI if Ollama is not running
AI_PROVIDER=auto

# Ollama settings (local inference — no internet required)
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI settings (cloud fallback)
OPENAI_MODEL=gpt-4o

# --- Whisper STT Tuning ---
# Model size: tiny (fastest) | base (default) | small (best Hindi) | medium | large
WHISPER_MODEL_SIZE=base

# Hearing sensitivity: lower = hears softer voices (int16 scale 0-32767)
# Default 300. Raise to 600+ if background noise causes false triggers.
SILENCE_THRESHOLD=300

# Seconds of silence before stopping recording. Lower = snappier.
SILENCE_TIMEOUT=1.2

# Hard cap on recording duration (seconds)
MAX_RECORD_SECS=12
